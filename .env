# Database
# For local dev outside Docker, point at your local Postgres:
# DATABASE_URL=postgresql://tournament_user:tournament_pass@localhost:5432/tournament
# For Docker Compose, the DATABASE_URL env is set directly in docker-compose.yml
DATABASE_URL=sqlite:///./tournament.db

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880  # 5MB